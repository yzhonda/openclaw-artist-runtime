{
  "$schema": "https://openclaw.ai/schemas/openclaw.plugin.schema.json",
  "id": "artist-runtime",
  "name": "Artist Runtime",
  "description": "Runs OpenClaw as a public autonomous AI musician using Suno and social distribution.",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "kind": "tool",
  "categories": [
    "music",
    "social",
    "automation",
    "creator-tools"
  ],
  "tags": [
    "artist",
    "suno",
    "x",
    "instagram",
    "tiktok",
    "public-artist",
    "autopilot"
  ],
  "license": "MIT",
  "homepage": "https://github.com/your-org/openclaw-artist-runtime",
  "repository": "https://github.com/your-org/openclaw-artist-runtime",
  "capabilities": {
    "tools": [
      "artist_song_ideate",
      "artist_suno_create_prompt_pack",
      "artist_suno_generate",
      "artist_suno_import_results",
      "artist_take_select",
      "artist_social_publish",
      "artist_social_reply"
    ],
    "hooks": [
      "agent:bootstrap",
      "before_tool_call",
      "after_tool_call"
    ],
    "services": [
      "artistAutopilotService",
      "sunoBrowserWorker",
      "socialDistributionWorker"
    ],
    "httpRoutes": [
      "/plugins/artist-runtime",
      "/plugins/artist-runtime/api/*"
    ]
  },
  "externalServices": [
    "Suno",
    "X/Twitter via Bird",
    "Instagram Content Publishing",
    "TikTok Content Posting"
  ],
  "security": {
    "requiresLoginBrowserProfile": true,
    "usesOAuth": [
      "instagram",
      "tiktok"
    ],
    "usesLocalCli": [
      "bird"
    ],
    "storesCredentials": false,
    "publicSideEffects": true,
    "auditLog": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "artist": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": {
            "type": "string",
            "const": "public_artist",
            "default": "public_artist"
          },
          "artistId": {
            "type": "string",
            "default": "artist"
          },
          "profilePath": {
            "type": "string",
            "default": "ARTIST.md"
          },
          "workspaceRoot": {
            "type": "string",
            "default": "."
          }
        },
        "required": [
          "mode"
        ]
      },
      "autopilot": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "songsPerWeek": {
            "type": "integer",
            "minimum": 0,
            "maximum": 21,
            "default": 3
          },
          "cycleIntervalMinutes": {
            "type": "integer",
            "minimum": 15,
            "maximum": 1440,
            "default": 180
          },
          "producerDigest": {
            "type": "string",
            "enum": [
              "off",
              "daily",
              "important_events",
              "high_touch"
            ],
            "default": "daily"
          }
        }
      },
      "music": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "engine": {
            "type": "string",
            "enum": [
              "suno"
            ],
            "default": "suno"
          },
          "suno": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "connectionMode": {
                "type": "string",
                "enum": [
                  "manual_copy",
                  "background_browser_worker",
                  "api_provider"
                ],
                "default": "background_browser_worker"
              },
              "driver": {
                "type": "string",
                "enum": [
                  "mock",
                  "playwright"
                ],
                "default": "mock",
                "description": "Suno browser driver selection. 'mock' keeps dry-run-safe skeleton behavior. 'playwright' is reserved for operator machines that install playwright separately."
              },
              "authority": {
                "type": "string",
                "enum": [
                  "prepare_only",
                  "autofill_only",
                  "auto_create_with_budget",
                  "auto_create_and_select_take"
                ],
                "default": "auto_create_and_select_take"
              },
              "monthlyGenerationBudget": {
                "type": "integer",
                "minimum": 0,
                "maximum": 1000,
                "default": 50
              },
              "maxGenerationsPerDay": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100,
                "default": 4
              },
              "minMinutesBetweenCreates": {
                "type": "integer",
                "minimum": 1,
                "maximum": 1440,
                "default": 20
              },
              "stopOnLoginChallenge": {
                "type": "boolean",
                "default": true
              },
              "stopOnCaptcha": {
                "type": "boolean",
                "default": true
              },
              "stopOnPaymentPrompt": {
                "type": "boolean",
                "default": true
              },
              "promptLogging": {
                "type": "string",
                "enum": [
                  "full"
                ],
                "default": "full"
              }
            }
          }
        }
      },
      "distribution": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "dailySharing": {
            "type": "string",
            "enum": [
              "off",
              "draft_only",
              "auto"
            ],
            "default": "auto"
          },
          "officialRelease": {
            "type": "string",
            "enum": [
              "manual_approval",
              "auto_with_release_policy"
            ],
            "default": "manual_approval"
          },
          "platforms": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "x": {
                "$ref": "#/$defs/xPlatform"
              },
              "instagram": {
                "$ref": "#/$defs/visualPlatform"
              },
              "tiktok": {
                "$ref": "#/$defs/videoPlatform"
              }
            }
          }
        }
      },
      "safety": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "auditLog": {
            "type": "boolean",
            "default": true
          },
          "failClosed": {
            "type": "boolean",
            "default": true
          },
          "forbiddenTopics": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "politics",
              "medical",
              "financial",
              "religion",
              "private_individuals",
              "legal_claims"
            ]
          },
          "forbidCaptchaBypass": {
            "type": "boolean",
            "default": true
          },
          "forbidCredentialLogging": {
            "type": "boolean",
            "default": true
          },
          "requireApprovalForHighRisk": {
            "type": "boolean",
            "default": true
          }
        }
      }
    },
    "$defs": {
      "xPlatform": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "connector": {
            "type": "string",
            "const": "bird",
            "default": "bird"
          },
          "authority": {
            "type": "string",
            "enum": [
              "draft_only",
              "auto_publish",
              "auto_publish_and_low_risk_replies"
            ],
            "default": "auto_publish"
          },
          "maxPostsPerDay": {
            "type": "integer",
            "minimum": 0,
            "maximum": 50,
            "default": 3
          },
          "maxRepliesPerDay": {
            "type": "integer",
            "minimum": 0,
            "maximum": 200,
            "default": 0
          },
          "autoPostTypes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "observation",
              "studio_note",
              "lyric_fragment",
              "demo_teaser",
              "new_song_link"
            ]
          }
        }
      },
      "visualPlatform": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "connector": {
            "type": "string",
            "const": "instagram_content_publishing",
            "default": "instagram_content_publishing"
          },
          "authority": {
            "type": "string",
            "enum": [
              "draft_only",
              "auto_publish_visuals"
            ],
            "default": "auto_publish_visuals"
          },
          "maxPostsPerDay": {
            "type": "integer",
            "minimum": 0,
            "maximum": 20,
            "default": 1
          },
          "autoPostTypes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "lyric_card",
              "reel_teaser",
              "cover_visual"
            ]
          }
        }
      },
      "videoPlatform": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "connector": {
            "type": "string",
            "const": "tiktok_content_posting",
            "default": "tiktok_content_posting"
          },
          "authority": {
            "type": "string",
            "enum": [
              "draft_only",
              "auto_publish_clips"
            ],
            "default": "auto_publish_clips"
          },
          "maxPostsPerDay": {
            "type": "integer",
            "minimum": 0,
            "maximum": 20,
            "default": 1
          },
          "autoPostTypes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "hook_clip",
              "demo_teaser"
            ]
          }
        }
      }
    }
  },
  "uiHints": {
    "artist.artistId": {
      "label": "Artist ID",
      "help": "Stable local ID used for folders, logs, and ledgers."
    },
    "autopilot.enabled": {
      "label": "Autopilot",
      "help": "When enabled, the artist can autonomously make songs and publish within configured limits."
    },
    "autopilot.dryRun": {
      "label": "Dry run",
      "help": "When on, no external posts or Suno create actions are executed."
    },
    "music.suno.connectionMode": {
      "label": "Suno connection",
      "help": "Use a background logged-in browser profile, manual copy fallback, or a future API provider."
    },
    "music.suno.driver": {
      "label": "Suno browser driver",
      "help": "Select 'mock' for the built-in dry-run skeleton or 'playwright' after the operator installs playwright locally."
    },
    "music.suno.authority": {
      "label": "Suno authority",
      "help": "How far the artist can go with Suno generation without producer intervention."
    },
    "music.suno.monthlyGenerationBudget": {
      "label": "Monthly Suno generation budget",
      "help": "Hard cap enforced by MusicAuthority."
    },
    "distribution.enabled": {
      "label": "Social distribution",
      "help": "Allow the artist to share finished work or daily progress publicly."
    },
    "distribution.platforms.x.enabled": {
      "label": "Enable X",
      "help": "Uses Bird as the X connector."
    },
    "distribution.platforms.instagram.enabled": {
      "label": "Enable Instagram",
      "help": "Uses Instagram Content Publishing API where available."
    },
    "distribution.platforms.tiktok.enabled": {
      "label": "Enable TikTok",
      "help": "Uses TikTok Content Posting API where available."
    },
    "safety.auditLog": {
      "label": "Audit log",
      "help": "Append-only log of public side effects and significant internal actions."
    }
  }
}
