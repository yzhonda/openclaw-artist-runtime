{
  "$schema": "https://openclaw.ai/schemas/openclaw.plugin.schema.json",
  "id": "artist-runtime",
  "name": "Artist Runtime",
  "description": "Runs OpenClaw as a public autonomous AI musician using Suno and social distribution.",
  "version": "0.3.0",
  "main": "./dist/index.js",
  "kind": "tool",
  "categories": [
    "music",
    "social",
    "automation",
    "creator-tools"
  ],
  "tags": [
    "artist",
    "suno",
    "x",
    "instagram",
    "tiktok",
    "public-artist",
    "autopilot"
  ],
  "license": "MIT",
  "homepage": "https://github.com/yzhonda/openclaw-artist-runtime",
  "repository": "https://github.com/yzhonda/openclaw-artist-runtime",
  "capabilities": {
    "tools": [
      "artist_song_ideate",
      "artist_suno_create_prompt_pack",
      "artist_suno_generate",
      "artist_suno_import_results",
      "artist_take_select",
      "artist_social_publish",
      "artist_social_reply"
    ],
    "hooks": [
      "agent:bootstrap",
      "before_tool_call",
      "after_tool_call"
    ],
    "services": [
      "artistAutopilotService",
      "sunoBrowserWorker",
      "socialDistributionWorker"
    ],
    "httpRoutes": [
      "/plugins/artist-runtime",
      "/plugins/artist-runtime/api/*"
    ]
  },
  "externalServices": [
    "Suno",
    "X/Twitter via Bird",
    "Instagram Content Publishing",
    "TikTok Content Posting"
  ],
  "security": {
    "requiresLoginBrowserProfile": true,
    "usesOAuth": [
      "instagram",
      "tiktok"
    ],
    "usesLocalCli": [
      "bird"
    ],
    "storesCredentials": false,
    "publicSideEffects": true,
    "auditLog": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "schemaVersion": {
        "type": "integer",
        "minimum": 1,
        "maximum": 1,
        "default": 1
      },
      "artist": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": {
            "type": "string",
            "const": "public_artist",
            "default": "public_artist"
          },
          "artistId": {
            "type": "string",
            "default": "artist"
          },
          "profilePath": {
            "type": "string",
            "default": "ARTIST.md"
          },
          "workspaceRoot": {
            "type": "string",
            "default": "."
          }
        },
        "required": [
          "mode"
        ]
      },
      "autopilot": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "songsPerWeek": {
            "type": "integer",
            "minimum": 0,
            "maximum": 21,
            "default": 3
          },
          "cycleIntervalMinutes": {
            "type": "integer",
            "minimum": 15,
            "maximum": 1440,
            "default": 180
          },
          "producerDigest": {
            "type": "string",
            "enum": [
              "off",
              "daily",
              "important_events",
              "high_touch"
            ],
            "default": "daily"
          }
        }
      },
      "music": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "engine": {
            "type": "string",
            "enum": [
              "suno"
            ],
            "default": "suno"
          },
          "suno": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "connectionMode": {
                "type": "string",
                "enum": [
                  "manual_copy",
                  "background_browser_worker",
                  "api_provider"
                ],
                "default": "background_browser_worker"
              },
              "driver": {
                "type": "string",
                "enum": [
                  "mock",
                  "playwright"
                ],
                "default": "mock",
                "description": "Suno browser driver selection. 'mock' keeps dry-run-safe skeleton behavior. 'playwright' is reserved for operator machines that install playwright separately."
              },
              "submitMode": {
                "type": "string",
                "enum": [
                  "skip",
                  "live"
                ],
                "default": "skip",
                "description": "Suno create submit mode. 'skip' fills the create form but never clicks Create, so credit consumption stays at zero. 'live' is reserved for a later round and is currently rejected at runtime."
              },
              "authority": {
                "type": "string",
                "enum": [
                  "prepare_only",
                  "autofill_only",
                  "auto_create_with_budget",
                  "auto_create_and_select_take"
                ],
                "default": "auto_create_and_select_take"
              },
              "dailyCreditLimit": {
                "type": "integer",
                "minimum": 1,
                "maximum": 1000,
                "default": 60
              },
              "monthlyCreditLimit": {
                "type": "integer",
                "minimum": 0,
                "maximum": 50000,
                "default": 0
              },
              "monthlyGenerationBudget": {
                "type": "integer",
                "minimum": 0,
                "maximum": 1000,
                "default": 50
              },
              "maxGenerationsPerDay": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100,
                "default": 4
              },
              "minMinutesBetweenCreates": {
                "type": "integer",
                "minimum": 1,
                "maximum": 1440,
                "default": 20
              },
              "stopOnLoginChallenge": {
                "type": "boolean",
                "default": true
              },
              "stopOnCaptcha": {
                "type": "boolean",
                "default": true
              },
              "stopOnPaymentPrompt": {
                "type": "boolean",
                "default": true
              },
              "promptLogging": {
                "type": "string",
                "enum": [
                  "full"
                ],
                "default": "full"
              }
            }
          }
        }
      },
      "distribution": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "liveGoArmed": {
            "type": "boolean",
            "default": false
          },
          "dailySharing": {
            "type": "string",
            "enum": [
              "off",
              "draft_only",
              "auto"
            ],
            "default": "auto"
          },
          "officialRelease": {
            "type": "string",
            "enum": [
              "manual_approval",
              "auto_with_release_policy"
            ],
            "default": "manual_approval"
          },
          "platforms": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "x": {
                "$ref": "#/$defs/xPlatform"
              },
              "instagram": {
                "$ref": "#/$defs/visualPlatform"
              },
              "tiktok": {
                "$ref": "#/$defs/videoPlatform"
              }
            }
          }
        }
      },
      "telegram": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "pollIntervalMs": {
            "type": "integer",
            "minimum": 500,
            "maximum": 60000,
            "default": 2000
          },
          "notifyStages": {
            "type": "boolean",
            "default": true
          },
          "acceptFreeText": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "artistPulse": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "minIntervalHours": {
            "type": "integer",
            "minimum": 6,
            "maximum": 168,
            "default": 12
          }
        }
      },
      "aiReview": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "mock",
              "openclaw"
            ],
            "default": "mock",
            "description": "Debug-only AI review provider. 'mock' never calls an external model; 'openclaw' is reserved until a provider is configured."
          }
        }
      },
      "safety": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "auditLog": {
            "type": "boolean",
            "default": true
          },
          "failClosed": {
            "type": "boolean",
            "default": true
          },
          "forbiddenTopics": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "politics",
              "medical",
              "financial",
              "religion",
              "private_individuals",
              "legal_claims"
            ]
          },
          "forbidCaptchaBypass": {
            "type": "boolean",
            "default": true
          },
          "forbidCredentialLogging": {
            "type": "boolean",
            "default": true
          },
          "requireApprovalForHighRisk": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "commission": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          }
        },
        "default": {
          "enabled": false
        }
      },
      "songSpawn": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "minIntervalHours": {
            "type": "integer",
            "minimum": 12,
            "maximum": 168,
            "default": 24
          }
        },
        "default": {
          "enabled": false,
          "minIntervalHours": 24
        }
      }
    },
    "$defs": {
      "xPlatform": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "liveGoArmed": {
            "type": "boolean",
            "default": false
          },
          "authStatus": {
            "type": "string",
            "enum": [
              "unconfigured",
              "configured",
              "tested",
              "failed"
            ],
            "default": "unconfigured"
          },
          "lastTestedAt": {
            "type": "integer",
            "minimum": 0
          },
          "connector": {
            "type": "string",
            "const": "bird",
            "default": "bird"
          },
          "authority": {
            "type": "string",
            "enum": [
              "draft_only",
              "auto_publish",
              "auto_publish_and_low_risk_replies"
            ],
            "default": "auto_publish"
          },
          "maxPostsPerDay": {
            "type": "integer",
            "minimum": 0,
            "maximum": 50,
            "default": 3
          },
          "maxRepliesPerDay": {
            "type": "integer",
            "minimum": 0,
            "maximum": 200,
            "default": 0
          },
          "autoPostTypes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "observation",
              "studio_note",
              "lyric_fragment",
              "demo_teaser",
              "new_song_link"
            ]
          }
        }
      },
      "visualPlatform": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "liveGoArmed": {
            "type": "boolean",
            "default": false
          },
          "authStatus": {
            "type": "string",
            "enum": [
              "unconfigured",
              "configured",
              "tested",
              "failed"
            ],
            "default": "unconfigured"
          },
          "lastTestedAt": {
            "type": "integer",
            "minimum": 0
          },
          "liveRehearsalArmed": {
            "type": "boolean",
            "default": false
          },
          "accessTokenExpiresAt": {
            "type": "integer",
            "minimum": 0
          },
          "connector": {
            "type": "string",
            "const": "instagram_content_publishing",
            "default": "instagram_content_publishing"
          },
          "authority": {
            "type": "string",
            "enum": [
              "draft_only",
              "auto_publish_visuals"
            ],
            "default": "auto_publish_visuals"
          },
          "maxPostsPerDay": {
            "type": "integer",
            "minimum": 0,
            "maximum": 20,
            "default": 1
          },
          "autoPostTypes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "lyric_card",
              "reel_teaser",
              "cover_visual"
            ]
          }
        }
      },
      "videoPlatform": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "liveGoArmed": {
            "type": "boolean",
            "default": false
          },
          "authStatus": {
            "type": "string",
            "enum": [
              "unconfigured",
              "configured",
              "tested",
              "failed"
            ],
            "default": "unconfigured"
          },
          "lastTestedAt": {
            "type": "integer",
            "minimum": 0
          },
          "connector": {
            "type": "string",
            "const": "tiktok_content_posting",
            "default": "tiktok_content_posting"
          },
          "authority": {
            "type": "string",
            "enum": [
              "draft_only",
              "auto_publish_clips"
            ],
            "default": "auto_publish_clips"
          },
          "maxPostsPerDay": {
            "type": "integer",
            "minimum": 0,
            "maximum": 20,
            "default": 1
          },
          "autoPostTypes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "hook_clip",
              "demo_teaser"
            ]
          }
        }
      }
    }
  },
  "uiHints": {
    "artist.artistId": {
      "label": "Artist ID",
      "help": "Stable local ID used for folders, logs, and ledgers."
    },
    "autopilot.enabled": {
      "label": "Autopilot",
      "help": "When enabled, the artist can autonomously make songs and publish within configured limits."
    },
    "autopilot.dryRun": {
      "label": "Dry run",
      "help": "When on, no external posts or Suno create actions are executed."
    },
    "music.suno.connectionMode": {
      "label": "Suno connection",
      "help": "Use a background logged-in browser profile, manual copy fallback, or a future API provider."
    },
    "music.suno.driver": {
      "label": "Suno browser driver",
      "help": "Select 'mock' for the built-in dry-run skeleton or 'playwright' after the operator installs playwright locally."
    },
    "music.suno.submitMode": {
      "label": "Suno submit mode",
      "help": "Keep 'skip' to fill the Suno form without clicking Create. 'live' is reserved for a later round and is currently blocked."
    },
    "music.suno.authority": {
      "label": "Suno authority",
      "help": "How far the artist can go with Suno generation without producer intervention."
    },
    "music.suno.dailyCreditLimit": {
      "label": "Daily Suno credit limit",
      "help": "Hard UTC-day cap for live Suno credit reservation before the Create click is allowed."
    },
    "music.suno.monthlyCreditLimit": {
      "label": "Monthly Suno credit limit",
      "help": "Optional UTC-month cap for live Suno credit reservations. 0 keeps the monthly gate unlimited."
    },
    "music.suno.monthlyGenerationBudget": {
      "label": "Monthly Suno generation budget",
      "help": "Hard cap enforced by MusicAuthority."
    },
    "distribution.enabled": {
      "label": "Social distribution",
      "help": "Allow the artist to share finished work or daily progress publicly."
    },
    "distribution.liveGoArmed": {
      "label": "Live social publishing arm",
      "help": "Keep OFF by default. When false, every social publish path is forced back into dry-run before any connector publish call."
    },
    "distribution.platforms.x.liveGoArmed": {
      "label": "Arm X live lane",
      "help": "Even if the global live arm is on, X stays forced into dry-run until this platform arm is also turned on."
    },
    "distribution.platforms.x.enabled": {
      "label": "Enable X",
      "help": "Uses Bird as the X connector."
    },
    "distribution.platforms.instagram.liveGoArmed": {
      "label": "Arm Instagram live lane",
      "help": "Even if the global live arm is on, Instagram stays forced into dry-run until this platform arm is also turned on."
    },
    "distribution.platforms.instagram.enabled": {
      "label": "Enable Instagram",
      "help": "Uses Instagram Content Publishing API where available."
    },
    "distribution.platforms.tiktok.liveGoArmed": {
      "label": "Arm TikTok live lane",
      "help": "Even if the global live arm is on, TikTok stays forced into dry-run until this platform arm is also turned on."
    },
    "distribution.platforms.tiktok.enabled": {
      "label": "Enable TikTok",
      "help": "Uses TikTok Content Posting API where available."
    },
    "telegram.enabled": {
      "label": "Telegram bot",
      "help": "Opt-in long-poll Telegram bridge. Requires local environment gates before it starts."
    },
    "telegram.pollIntervalMs": {
      "label": "Telegram poll interval",
      "help": "Delay between long-poll cycles after a completed Telegram poll."
    },
    "telegram.notifyStages": {
      "label": "Telegram stage notifications",
      "help": "Prepare stage notification routing. No Telegram worker starts unless all local opt-in gates are present."
    },
    "telegram.acceptFreeText": {
      "label": "Telegram free-text inbox",
      "help": "Allow owner free-text messages to be staged for a later operator inbox path."
    },
    "aiReview.provider": {
      "label": "Debug AI review provider",
      "help": "Debug-only review provider for /review. Mock is safe and does not affect take selection or publishing."
    },
    "safety.auditLog": {
      "label": "Audit log",
      "help": "Append-only log of public side effects and significant internal actions."
    }
  }
}
