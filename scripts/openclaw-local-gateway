#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "${script_dir}/openclaw-local-env.sh"

command="${1:-run}"
if [[ $# -gt 0 ]]; then
  shift
fi

common_args=(
  --allow-unconfigured
  --bind loopback
  --auth none
  --port "${OPENCLAW_LOCAL_GATEWAY_PORT}"
)

ensure_runtime_dirs() {
  mkdir -p "${OPENCLAW_LOCAL_ROOT}" "${OPENCLAW_HOME}" "${OPENCLAW_STATE_DIR}" "${OPENCLAW_LOCAL_WORKSPACE}" "${OPENCLAW_LOCAL_LOGS}" "$(dirname "${OPENCLAW_CONFIG_PATH}")"
}

ensure_gateway_config() {
  node <<'EOF'
const crypto = require("node:crypto");
const fs = require("node:fs");
const path = require("node:path");

const configPath = process.env.OPENCLAW_CONFIG_PATH;
if (!configPath) {
  process.exit(0);
}

let config = {};
try {
  config = JSON.parse(fs.readFileSync(configPath, "utf8"));
} catch {
  config = {};
}

config.gateway ??= {};
config.gateway.auth ??= {};
if (typeof config.gateway.auth.mode !== "string" || config.gateway.auth.mode.trim().length === 0) {
  config.gateway.auth.mode = "none";
}
if (typeof config.gateway.auth.token !== "string" || config.gateway.auth.token.trim().length === 0) {
  config.gateway.auth.token = crypto.randomBytes(24).toString("hex");
}

fs.mkdirSync(path.dirname(configPath), { recursive: true });
fs.writeFileSync(configPath, `${JSON.stringify(config, null, 2)}\n`, "utf8");
EOF
}

read_gateway_token() {
  node <<'EOF'
const fs = require("node:fs");

const configPath = process.env.OPENCLAW_CONFIG_PATH;
if (!configPath) {
  process.exit(0);
}

try {
  const config = JSON.parse(fs.readFileSync(configPath, "utf8"));
  const token = typeof config.gateway?.auth?.token === "string" ? config.gateway.auth.token.trim() : "";
  if (token) {
    process.stdout.write(token);
  }
} catch {}
EOF
}

read_gateway_pid() {
  if [[ -f "${OPENCLAW_LOCAL_GATEWAY_PID}" ]]; then
    tr -d '[:space:]' < "${OPENCLAW_LOCAL_GATEWAY_PID}"
  fi
}

gateway_pid_is_live() {
  local pid="$1"
  [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null
}

cleanup_stale_pid() {
  local pid
  pid="$(read_gateway_pid)"
  if [[ -n "${pid}" ]] && ! gateway_pid_is_live "${pid}"; then
    rm -f "${OPENCLAW_LOCAL_GATEWAY_PID}"
  fi
}

case "${command}" in
  run)
    ensure_runtime_dirs
    ensure_gateway_config
    exec "${script_dir}/openclaw-local" gateway run "${common_args[@]}" "$@"
    ;;
  start)
    ensure_runtime_dirs
    ensure_gateway_config
    cleanup_stale_pid
    existing_pid="$(read_gateway_pid)"
    if gateway_pid_is_live "${existing_pid:-}"; then
      echo "Gateway already running (pid ${existing_pid})." >&2
      exit 0
    fi
    : > "${OPENCLAW_LOCAL_GATEWAY_LOG}"
    nohup "${script_dir}/openclaw-local" gateway run "${common_args[@]}" "$@" \
      >>"${OPENCLAW_LOCAL_GATEWAY_LOG}" 2>&1 < /dev/null &
    gateway_pid=$!
    echo "${gateway_pid}" > "${OPENCLAW_LOCAL_GATEWAY_PID}"
    for _ in $(seq 1 20); do
      if "${script_dir}/openclaw-local-http-smoke.sh" >/dev/null 2>&1; then
        echo "Gateway started (pid ${gateway_pid})."
        echo "Log: ${OPENCLAW_LOCAL_GATEWAY_LOG}"
        exit 0
      fi
      sleep 1
      if ! gateway_pid_is_live "${gateway_pid}"; then
        echo "Gateway failed to stay up. Log: ${OPENCLAW_LOCAL_GATEWAY_LOG}" >&2
        rm -f "${OPENCLAW_LOCAL_GATEWAY_PID}"
        exit 1
      fi
    done
    echo "Gateway did not become ready in time. Log: ${OPENCLAW_LOCAL_GATEWAY_LOG}" >&2
    exit 1
    ;;
  stop)
    cleanup_stale_pid
    existing_pid="$(read_gateway_pid)"
    if [[ -z "${existing_pid}" ]]; then
      echo "Gateway is not running."
      exit 0
    fi
    kill "${existing_pid}" 2>/dev/null || true
    for _ in $(seq 1 10); do
      if ! gateway_pid_is_live "${existing_pid}"; then
        rm -f "${OPENCLAW_LOCAL_GATEWAY_PID}"
        echo "Gateway stopped."
        exit 0
      fi
      sleep 1
    done
    kill -9 "${existing_pid}" 2>/dev/null || true
    rm -f "${OPENCLAW_LOCAL_GATEWAY_PID}"
    echo "Gateway force-stopped."
    ;;
  tail)
    ensure_runtime_dirs
    touch "${OPENCLAW_LOCAL_GATEWAY_LOG}"
    exec tail -n "${TAIL_LINES:-40}" -f "${OPENCLAW_LOCAL_GATEWAY_LOG}"
    ;;
  health)
    gateway_token="$(read_gateway_token)"
    if [[ -n "${gateway_token}" ]]; then
      exec "${script_dir}/openclaw-local" gateway health --json --url "${OPENCLAW_LOCAL_GATEWAY_WS_URL}" --token "${gateway_token}" "$@"
    fi
    exec "${script_dir}/openclaw-local" gateway health --json --url "${OPENCLAW_LOCAL_GATEWAY_WS_URL}" "$@"
    ;;
  probe)
    gateway_token="$(read_gateway_token)"
    if [[ -n "${gateway_token}" ]]; then
      exec "${script_dir}/openclaw-local" gateway probe --json --url "${OPENCLAW_LOCAL_GATEWAY_WS_URL}" --token "${gateway_token}" "$@"
    fi
    exec "${script_dir}/openclaw-local" gateway probe --json --url "${OPENCLAW_LOCAL_GATEWAY_WS_URL}" "$@"
    ;;
  status)
    cleanup_stale_pid
    existing_pid="$(read_gateway_pid)"
    if [[ -n "${existing_pid}" ]]; then
      echo "gateway_pid=${existing_pid}"
      echo "gateway_log=${OPENCLAW_LOCAL_GATEWAY_LOG}"
    else
      echo "gateway_pid=stopped"
      echo "gateway_log=${OPENCLAW_LOCAL_GATEWAY_LOG}"
    fi
    gateway_token="$(read_gateway_token)"
    if [[ -n "${gateway_token}" ]]; then
      exec "${script_dir}/openclaw-local" gateway status --url "${OPENCLAW_LOCAL_GATEWAY_WS_URL}" --token "${gateway_token}" "$@"
    fi
    exec "${script_dir}/openclaw-local" gateway status --url "${OPENCLAW_LOCAL_GATEWAY_WS_URL}" "$@"
    ;;
  *)
    echo "Usage: scripts/openclaw-local-gateway [run|start|stop|tail|health|probe|status] [args...]" >&2
    exit 1
    ;;
esac
